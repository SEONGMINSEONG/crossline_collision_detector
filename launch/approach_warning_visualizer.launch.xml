<?xml version="1.0"?>
<launch>
  <arg name="input_approach_warnings" default="/intersection_risk_analyzer/output/approach_warnings"/>
  <arg name="param_file" default="$(find-pkg-share crossline_collision_detector)/config/approach_warning_visualizer.param.yaml"/>

  <node pkg="crossline_collision_detector"
        exec="approach_warning_visualizer_exe"
        name="approach_warning_visualizer"
        output="screen">
    <remap from="~/input/approach_warnings" to="$(var input_approach_warnings)"/>
    <param from="$(var param_file)"/>
  </node>
</launch>
